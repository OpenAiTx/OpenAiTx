  {
    "row": 53,
    "rowsha": "k3gc7uoSaXaBBYK9liSlU7MWRHcHGfYpT6UrwZTyctw=",
    "originContent": "alias tailscale='docker exec -it tailscaled tailscale'",
    "translatedContent": "alias tailscale='docker exec -it tailscaled tailscale'"
