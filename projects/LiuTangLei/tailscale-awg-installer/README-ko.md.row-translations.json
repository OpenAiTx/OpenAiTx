  {
    "row": 37,
    "rowsha": "bcoEEVSAigg4tcoBLH7leW9haz+WSJWuiZNStOesapQ=",
    "originContent": "cp -a /var/lib/tailscale ./tailscale-state",
    "translatedContent": "cp -a /var/lib/tailscale ./tailscale-state"
  },
