    "Content": "```\nmake module_compile\n```",
    "ContentSha": "snd8ZGORVXXgvbOW8amF5VEhnJX2a1+4zMP6Pn6Ep68=",
    "SectionType": "",
    "StartLine": 0,
    "EndLine": 0,
    "Translation": "```\nmake module_compile\n```",
    "Status": "ok",
    "RowTranslations": [],
    "IsCodeBlock": true
  },
