    "Status": "ok",
    "RowTranslations": [],
    "IsCodeBlock": true
  },
  {
    "Id": 23,
    "Content": "To install the compressed module to the system's kernel module, run in terminal",
    "ContentSha": "LfyHXMUY10Iszb6JOQJh/L2GRVeaFIme+Wm0SmQ9xtQ=",
    "SectionType": "",
