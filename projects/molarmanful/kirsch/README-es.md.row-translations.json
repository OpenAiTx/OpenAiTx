  },
  {
    "row": 164,
    "rowsha": "b76l4fZTl5GtAiqTE7RMBs9yHjiTK6yzvSFkdbhDpSQ=",
    "originContent": "are edited via [bited](https://github.com/molarmanful/bited).",
    "translatedContent": ""
  },
  {
    "row": 165,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": "## Créditos"
  },
  {
    "row": 166,
    "rowsha": "OtBYwndH58Q+LfPUO9DkPBo3A7SzyLFdEA2wIljgYwk=",
    "originContent": "## Credits",
    "translatedContent": ""
  },
