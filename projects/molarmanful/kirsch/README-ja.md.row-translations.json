    "originContent": "### Nix Flakes",
    "translatedContent": "kirschのリリースは"
  },
  {
    "row": 111,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
