    "row": 22,
    "rowsha": "6C6Kuuxwacu2h4MPBRwL4mNhjPej/ASP4C/ahXFiKpg=",
    "originContent": "Clone the repo:",
    "translatedContent": "레포지토리를 클론하세요:"
  },
  {
    "row": 23,
    "rowsha": "yDlCDDv3pWWndTYwnoSg8/UlpNew9/1Gv9OJCrtvW0s=",
    "originContent": " - `git clone https://github.com/andwn/marsdev --recurse-submodules`",
    "translatedContent": " - `git clone https://github.com/andwn/marsdev --recurse-submodules`"
  },
  {
    "row": 24,
    "rowsha": "ORCesMYK9K0hNigrsdSfXB25QI/v+OstDcwJ3lqTIjA=",
    "originContent": " - `cd marsdev`",
    "translatedContent": " - `cd marsdev`"
  },
  {
    "row": 25,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
