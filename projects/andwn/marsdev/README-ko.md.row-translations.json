    "originContent": "",
    "translatedContent": ""
  },
  {
    "row": 121,
    "rowsha": "6pG+/NqJqBMsjuzuI3xIvexvYfEUkPvTL4eEkcvwvYg=",
    "originContent": " - `sudo apt install -y git build-essential texinfo wget openjdk-11-jre`",
    "translatedContent": " - `sudo apt install -y git build-essential texinfo wget openjdk-11-jre`"
  },
  {
    "row": 122,
    "rowsha": "USDoH55xwHjLfWTFKr3vXu5XSeN+5HEAOisCJE+AEPQ=",
    "originContent": " - `git clone https://github.com/andwn/marsdev && cd marsdev`",
