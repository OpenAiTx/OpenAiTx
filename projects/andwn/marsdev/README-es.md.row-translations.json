  {
    "row": 53,
    "rowsha": "2fpH30/ZNT/4DtDNgBov7cyoIjtgUwOuXteZCpaoXag=",
    "originContent": " - `make m68k-toolchain-newlib GCC_VER=12.4.0 LANGS=c,c++`",
    "translatedContent": " - `make m68k-toolchain-newlib GCC_VER=12.4.0 LANGS=c,c++`"
  },
