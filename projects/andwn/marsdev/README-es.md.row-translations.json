  {
    "row": 58,
    "rowsha": "R3ucfRkOwkNS+KClXY+8cscNHYpXfLJfPIAgPhLaybs=",
    "originContent": "SGDK requires Java, so Install it.",
    "translatedContent": "SGDK requiere Java, así que instálelo."
  },
  {
    "row": 59,
    "rowsha": "Nl4P/JjiPfr2k5RuWEG1GThghBAlmTLEB44J0xhXqrk=",
    "originContent": "  * Debian: `apt install openjdk-11-jre`",
    "translatedContent": "  * Debian: `apt install openjdk-11-jre`"
  },
  {
    "row": 60,
    "rowsha": "YkpbVOUKjqCDwOgUhxBhMIoM68jOIG/ePQNVAmjUHvQ=",
    "originContent": "  * RedHat: `yum install java-11-openjdk`",
    "translatedContent": "  * RedHat: `yum install java-11-openjdk`"
  },
  {
    "row": 61,
    "rowsha": "bZ32hq5DiYL7teoddBpt45oRT4jVOlx2YPdic3v375A=",
    "originContent": "  * Arch: `pacman -S jdk11-openjdk`",
    "translatedContent": "  * Arch: `pacman -S jdk11-openjdk`"
  },
  {
    "row": 62,
    "rowsha": "5zs+LSqQ5ap88g36tSwgKcHCKoOZi6cDGiLOnpBYSNY=",
    "originContent": "  * Gentoo: `emerge dev-java/openjdk`",
    "translatedContent": "  * Gentoo: `emerge dev-java/openjdk`"
  },
