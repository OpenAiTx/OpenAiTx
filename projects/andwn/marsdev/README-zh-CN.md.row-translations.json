    "originContent": "",
    "translatedContent": "### 4.1（可选）其他工具"
  },
  {
    "row": 82,
    "rowsha": "y9XX/CfxlzUTFQru9NrOGm+SCFXdR2Skfb/GI7tw0gA=",
    "originContent": "### 4.1 (Optional) Other Tools",
