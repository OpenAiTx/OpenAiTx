    "originContent": " - `make sgdk`",
    "translatedContent": " - `make sgdk`"
  },
  {
    "row": 77,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
