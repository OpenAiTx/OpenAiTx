  },
  {
    "row": 118,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": "安装："
  },
  {
    "row": 119,
    "rowsha": "O+Zu3/m2wrPeCFf4lp5724xbxst86yoGssFXV375Jkw=",
    "originContent": "Install:",
    "translatedContent": ""
  },
  {
    "row": 120,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": ""
  },
  {
    "row": 121,
    "rowsha": "6pG+/NqJqBMsjuzuI3xIvexvYfEUkPvTL4eEkcvwvYg=",
    "originContent": " - `sudo apt install -y git build-essential texinfo wget openjdk-11-jre`",
