  {
    "row": 66,
    "rowsha": "iSETU3EH7+/eNQ+R25+E4w3/D3weimQSD21Kw4+5TY0=",
    "originContent": "**Note for macOS**",
    "translatedContent": "**Note pour macOS**"
  },
  {
    "row": 67,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
