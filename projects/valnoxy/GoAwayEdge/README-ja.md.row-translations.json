    "rowsha": "rKzqhW2vqCda4JxXy7m+dje+Zah6G1L+xC9v8+J6w6M=",
    "originContent": "2. Start the application.",
    "translatedContent": "2. アプリケーションを起動します。"
  },
  {
    "row": 68,
    "rowsha": "isnx6KzWci3eobzVrW3HRJrZfodtjOv94hIKHge/dew=",
    "originContent": "3. Accept the license.",
