    "rowsha": "hvHHx5lj/Z1x+s99lk39Q76SxR6VS+yyXv+p/4kdM6U=",
    "originContent": "| Switch                   | Description                                                                                                                    |",
    "translatedContent": "| スイッチ                  | 説明                                                                                                                    |"
