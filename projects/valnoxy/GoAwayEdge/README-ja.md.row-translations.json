    "row": 85,
    "rowsha": "LcyiNibYbs18uRfhJzPaaL6wjaX8CsHTUZj9Lmk5O7Q=",
    "originContent": "| `-w:<Weather Service>`   | Specify the Weather Service: `Default`, `WeatherCom`, `AccuWeather`                                                            |",
    "translatedContent": "| `-w:<Weather Service>`   | 天気サービスを指定: `Default`、`WeatherCom`、`AccuWeather`                                                                       |"
  },
  {
    "row": 86,
    "rowsha": "a6/Dj/g9bvsfKAdLky4waX57Us+lOdN7/45ROdaTadI=",
    "originContent": "| `--search-url:<Url>`     | Custom search query url (ex: `https://google.com/search?q=`)                                                                   |",
    "translatedContent": "| `--search-url:<Url>`     | カスタム検索クエリURL（例: `https://google.com/search?q=`）                                                                     |"
  },
  {
    "row": 87,
    "rowsha": "ouDCI4mfJ6DyKJa5m8vB1CWAbBUmLJoQxt2GzsWhrWM=",
    "originContent": "| `--ai-url:<Url>`         | Custom AI website (ex: `https://chatgpt.com`)                                                                                  |",
    "translatedContent": "| `--ai-url:<Url>`         | カスタムAIウェブサイト（例: `https://chatgpt.com`）                                                                             |"
