    "originContent": "## Hooks",
    "translatedContent": "## 후크(Hooks)"
  },
  {
    "row": 162,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
