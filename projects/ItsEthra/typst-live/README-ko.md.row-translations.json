  {
    "row": 28,
    "rowsha": "XU5Gjhq4+0uXjh0gxRM8H79i6qoLYq+5atWTsMef9Zw=",
    "originContent": "* Now edit your `file.typ` and watch changes appear in browser tab.",
    "translatedContent": "* 이제 `file.typ`를 편집하면 브라우저 탭에서 변경 사항이 나타납니다."
  },
  {
    "row": 29,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
