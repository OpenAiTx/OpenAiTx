  {
    "row": 16,
    "rowsha": "8bkBhHOQsO1+N058HkZOwXtGpCfEh6WtbL0pBkBQg9U=",
    "originContent": "```",
    "translatedContent": "```"
  },
  {
    "row": 17,
    "rowsha": "p3mXrrsZhy7oqSnwrs8BVt0b4brnzWaifIUvm5rNdTE=",
    "originContent": "nix run github:ItsEthra/typst-live",
    "translatedContent": "nix run github:ItsEthra/typst-live"
  },
  {
    "row": 18,
    "rowsha": "8bkBhHOQsO1+N058HkZOwXtGpCfEh6WtbL0pBkBQg9U=",
