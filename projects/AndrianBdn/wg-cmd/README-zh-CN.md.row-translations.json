    "row": 148,
    "rowsha": "H+EDaLcYyKY0iMRUZvPoQXCXCy+5fCR8ybEi6ftbmK4=",
    "originContent": "If you have created systemd units, you will need to remove them manually.",
    "translatedContent": "（请更改为您需要删除的接口）："
  },
