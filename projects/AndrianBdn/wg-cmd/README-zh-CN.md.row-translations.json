    "row": 143,
    "rowsha": "aLobb+JQAJjl7nnfNEOLx0mNkw0DOeyhTB9gsNILMQM=",
    "originContent": "### Uninstall ",
    "translatedContent": "您还可以删除目录/etc/wireguard/wgc-*和~/.config/wg-cmd"
