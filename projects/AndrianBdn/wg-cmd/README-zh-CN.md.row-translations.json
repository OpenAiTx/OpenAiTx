    "row": 98,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": "`ClientDNS` - 所有客户端的 DNS 配置值"
  },
  {
    "row": 99,
    "rowsha": "5Nm3VUiVeb3XFgnioNE4YndrtUeYq0siiclOjGcnep0=",
    "originContent": "`ClientDNS` - DNS configuration value for all clients",
