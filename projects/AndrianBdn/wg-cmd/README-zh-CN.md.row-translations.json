    "translatedContent": ""
  },
  {
    "row": 150,
    "rowsha": "s4CVUOhi2+USvHlG41Xh6UqjcnJmTVwO6XpBabmhfns=",
    "originContent": "Below is an example of how to remove WG Commander managed interface wg7 ",
    "translatedContent": ""
  },
