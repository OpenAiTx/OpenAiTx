  {
    "row": 18,
    "rowsha": "gCs/yRQqjvSeRPT1mrSi2/8TMlM05O/oOQJQBsbUU0g=",
    "originContent": "Reload and run `prefix-I` to fetch.",
    "translatedContent": "重新加载并运行 `prefix-I` 以获取。"
  },
