    "rowsha": "0pcZ8FWXhsLyNpFTBVVDaq++Ts2XzIJ/4PYZYtB41zE=",
    "originContent": "set -g @plugin 'saysjonathan/dwm.tmux'",
    "translatedContent": "set -g @plugin 'saysjonathan/dwm.tmux'"
