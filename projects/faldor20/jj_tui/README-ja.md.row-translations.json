    "rowsha": "TC5LIKdpJY8Bei4Mvb0bO1j7UKyhq8ggzu7R8YhK4AY=",
    "originContent": "To open a shell with jj_tui on nix: `nix shell github:faldor20/jj_tui`",
    "translatedContent": "nixでjj_tuiのシェルを開くには: `nix shell github:faldor20/jj_tui`"
  },
