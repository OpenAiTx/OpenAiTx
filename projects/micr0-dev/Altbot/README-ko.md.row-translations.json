    "row": 165,
    "rowsha": "/KALkMPDK09dQdL956DrWmvp1ZxI+1ZUfS8uNXK7OWk=",
    "originContent": "| Command        | Description                                        |",
    "translatedContent": "| -------------- | -------------------------------------------------- |"
  },
  {
    "row": 166,
    "rowsha": "NniVwzE/aYssCTlC4Tyqjs3y58Dtbk8blhgj13lheMQ=",
    "originContent": "| -------------- | -------------------------------------------------- |",
    "translatedContent": "| `/image <url>` | 이미지 URL을 처리하고 대체 텍스트 생성                  |"
  },
  {
    "row": 167,
    "rowsha": "0rM/A8P1oaYI/7kt5RrA/qRUkIueyAQ3moRcLA7J97Q=",
    "originContent": "| `/image <url>` | Process an image URL and generate alt-text         |",
    "translatedContent": "| `/video <url>` | 비디오 URL을 처리하고 대체 텍스트 생성                  |"
  },
  {
    "row": 168,
    "rowsha": "mMIIlXeLK3MgV1y71R+G9YeO8GIHKdZZHOyldMslk1k=",
    "originContent": "| `/video <url>` | Process a video URL and generate alt-text          |",
    "translatedContent": "| `/audio <url>` | 오디오 URL을 처리하고 대체 텍스트 생성                  |"
  },
  {
    "row": 169,
    "rowsha": "bE5foyBpSWxDc0zZDvXYatYQ+DkFVZEqYk/SPkT3vt4=",
    "originContent": "| `/audio <url>` | Process an audio URL and generate alt-text         |",
    "translatedContent": "| `/lang [code]` | 응답 언어 설정/보기 (예: en, de, ja)                   |"
  },
  {
    "row": 170,
    "rowsha": "4ho8MOeHXrqW+E30ub3hou5BlVurNT6kKgdaV8Q3eWA=",
    "originContent": "| `/lang [code]` | Set/show language for responses (e.g., en, de, ja) |",
    "translatedContent": "| `/follow`      | 팔로우 이벤트 시뮬레이션                               |"
  },
  {
    "row": 171,
    "rowsha": "aDBKevD0mimnTs/9yUMKGWtydaGlcEpKAp5/t5Cn9eQ=",
    "originContent": "| `/follow`      | Simulate a follow event                            |",
    "translatedContent": "| `/status`      | 현재 개발자 모드 상태 표시                             |"
  },
  {
    "row": 172,
    "rowsha": "IlyGQEnc/idwV8ljU2fdK6XDpIz8Zo8TVR4PgoX4foY=",
    "originContent": "| `/status`      | Show current dev mode status                       |",
    "translatedContent": "| `/help`        | 사용 가능한 명령어 표시                               |"
  },
  {
    "row": 173,
    "rowsha": "80he0Uy/U5BReJ87WfhWUIe1GyL/l8wFRyRmbX73ksE=",
    "originContent": "| `/help`        | Show available commands                            |",
    "translatedContent": "| `/quit`        | 개발자 모드 종료                                     |"
  },
