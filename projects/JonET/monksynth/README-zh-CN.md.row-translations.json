    "rowsha": "TXQF8+Bf4ng87hzbIHhzwNTz/IyrevCKnWred/VV0nc=",
    "originContent": "- `background.png` — main background (360x510)",
    "translatedContent": "- `background.png` — 主要背景（360x510）"
  },
