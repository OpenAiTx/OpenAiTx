    "translatedContent": "```"
  },
  {
    "row": 148,
    "rowsha": "Vg4hz6FaCcmglaVANBQ7Qjuc5b3SYVR3nQs5ayFHgVI=",
    "originContent": "mmseqs createdb protein.sequences.v12.0.fa DB100",
    "translatedContent": "mmseqs createdb protein.sequences.v12.0.fa DB100"
  },
  {
    "row": 149,
    "rowsha": "KFElvj+dzLI3t4nc3WUzVapBWf9b1QjKUyhNwnC7Bhg=",
    "originContent": "mmseqs cluster DB100 clu50 /tmp/mmseqs --min-seq-id 0.50 --remove-tmp-files",
    "translatedContent": "mmseqs cluster DB100 clu50 /tmp/mmseqs --min-seq-id 0.50 --remove-tmp-files"
  },
  {
    "row": 150,
    "rowsha": "nZSK3pIQW+JLMkmQBWyWJEPSO2Gg1EkuI+zBUW9gCJo=",
    "originContent": "mmseqs createtsv DB100 DB100 clu50 clu50.tsv",
