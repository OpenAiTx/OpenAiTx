    "row": 126,
    "rowsha": "jUBHct4io1t3f8DX836DXFPumvgFVv/t9+4Ku5+bc3E=",
    "originContent": "Two things happen automatically in the background:",
    "translatedContent": "后台自动发生两件事："
  },
  {
    "row": 127,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
