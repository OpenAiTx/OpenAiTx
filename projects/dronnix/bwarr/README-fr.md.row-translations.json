  },
  {
    "row": 10,
    "rowsha": "lhxbgBw4wghEwBUqgyyS4P0fmHLGNCWf8O44XgjbUmQ=",
    "originContent": "## Data Structure",
    "translatedContent": "## Structure de données"
  },
  {
    "row": 11,
    "rowsha": "lT+hp3xlMxyFfB74DQDXrmWasGpYsbZKh1+evR1yVFA=",
    "originContent": "The idea of Black-White Array was invented and published by professor [Z. George Mou](https://www.cs.brandeis.edu/~mou/) in [Black-White Array: A New Data Structure for",
    "translatedContent": "L'idée du Black-White Array a été inventée et publiée par le professeur [Z. George Mou](https://www.cs.brandeis.edu/~mou/) dans [Black-White Array: A New Data Structure for"
  },
  {
    "row": 12,
    "rowsha": "M88jdQzBqgNrpe/GKzgX35oT0iC4SP69w4KeTQwuWEk=",
    "originContent": "Dynamic Data Sets](https://arxiv.org/abs/2004.09051). This repository contains the first public implementation.",
    "translatedContent": "Dynamic Data Sets](https://arxiv.org/abs/2004.09051). Ce dépôt contient la première implémentation publique."
  },
  {
    "row": 13,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": ""
  },
