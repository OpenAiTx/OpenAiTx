    "row": 44,
    "rowsha": "NRqSNlhdVM6I4Zq/3kST6FTed24Zt+I2Is3snpRmOR8=",
    "originContent": "### Requirements ️✔️",
    "translatedContent": "### Vereisten ️✔️"
  },
  {
    "row": 45,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
