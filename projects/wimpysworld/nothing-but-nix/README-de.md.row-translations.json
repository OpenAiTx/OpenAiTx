    "row": 135,
    "rowsha": "JJeAEiNR2Odaxv6x9HtAeOZj1zKun9fKzeU3biUKhIE=",
    "originContent": "- NixOS VM tests that assemble large disk images",
    "translatedContent": "- NixOS-VM-Tests, die große Festplattenabbilder erstellen"
  },
