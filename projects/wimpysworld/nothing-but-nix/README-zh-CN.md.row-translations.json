    "row": 142,
    "rowsha": "b3AItER9R6JHnpRMEX9tUEto345WhT428Kk4q2cgT4U=",
    "originContent": "- uses: wimpysworld/nothing-but-nix@main",
    "translatedContent": "- uses: wimpysworld/nothing-but-nix@main"
  },
  {
    "row": 143,
    "rowsha": "PI+NwuhomK4iVx5cssnWfp+zdZq61aEbfpwurZJiEWw=",
    "originContent": "  with:",
    "translatedContent": "  with:"
  },
