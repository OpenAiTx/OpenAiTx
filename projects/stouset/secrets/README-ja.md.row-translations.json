    "originContent": "Panic Safety",
    "translatedContent": ""
  },
  {
    "row": 39,
    "rowsha": "FNRjaBTCOVFBIIC12Yl4Joa1sb1JGfDEzl1zl4V3KSU=",
    "originContent": "------------",
    "translatedContent": ""
