  {
    "row": 58,
    "rowsha": "uBwW9i/6uSKLc3UYJRAXHTIf2W98fjaFEPrHcmIc79s=",
    "originContent": "1. Create/Update the environmental file `.env`",
    "translatedContent": "1. أنشئ/حدّث ملف البيئة `.env`"
  },
  {
    "row": 59,
    "rowsha": "8bkBhHOQsO1+N058HkZOwXtGpCfEh6WtbL0pBkBQg9U=",
    "originContent": "```",
    "translatedContent": "```"
  },
  {
    "row": 60,
    "rowsha": "krrkWRxRBM58twU3RKbKowz+enMFgPRX8TFxoeCWf30=",
    "originContent": "# Vagrant image settings",
    "translatedContent": "# Vagrant image settings"
  },
  {
    "row": 61,
    "rowsha": "c97G6DoBoqfJAl4Ly/feovOL/m/RP6W9kFgLEsdd7QI=",
    "originContent": "MEMORY=8000     # MiB (~8 GB)",
    "translatedContent": "MEMORY=8000     # MiB (~8 GB)"
  },
  {
    "row": 62,
    "rowsha": "4bfi5uX1L048prxrw7xPA0A9ThOL2uJ/+QIcl+blY0c=",
    "originContent": "CPU=4",
    "translatedContent": "CPU=4"
  },
  {
    "row": 63,
    "rowsha": "5W9Xb+o8QgzbokKIpYHboHtvbls0fjFBf2mpX1x8UJA=",
    "originContent": "DISK_SIZE=100   # GiB",
    "translatedContent": "DISK_SIZE=100   # GiB"
  },
  {
    "row": 64,
    "rowsha": "8bkBhHOQsO1+N058HkZOwXtGpCfEh6WtbL0pBkBQg9U=",
    "originContent": "```",
    "translatedContent": "```"
  },
  {
    "row": 65,
    "rowsha": "IjqJFjuj86JKPnzLCU6I03DDR6LM3+Dkv5qxEsznwcs=",
    "originContent": "2. Create `docker-compose.yml`",
    "translatedContent": "2. أنشئ `docker-compose.yml`"
  },
