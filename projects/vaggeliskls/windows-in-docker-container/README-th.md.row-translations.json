    "originContent": "```",
    "translatedContent": "```"
  },
  {
    "row": 60,
    "rowsha": "krrkWRxRBM58twU3RKbKowz+enMFgPRX8TFxoeCWf30=",
    "originContent": "# Vagrant image settings",
    "translatedContent": "# Vagrant image settings"
  },
  {
    "row": 61,
    "rowsha": "c97G6DoBoqfJAl4Ly/feovOL/m/RP6W9kFgLEsdd7QI=",
    "originContent": "MEMORY=8000     # MiB (~8 GB)",
    "translatedContent": "MEMORY=8000     # MiB (~8 GB)"
  },
  {
