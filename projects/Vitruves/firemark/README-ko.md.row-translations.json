    "originContent": "<p align=\"center\">",
    "translatedContent": "## 설치 방법"
  },
  {
    "row": 60,
    "rowsha": "Cz8CjBYeCLIwiouKpclUc+YlpMb8qIDbOAzSKsULs78=",
    "originContent": "  <img src=\"https://raw.githubusercontent.com/Vitruves/firemark/main/assets/img/paycheck-firemark-comparison.png\" alt=\"Before and after watermarking\" width=\"800\">",
    "translatedContent": ""
  },
