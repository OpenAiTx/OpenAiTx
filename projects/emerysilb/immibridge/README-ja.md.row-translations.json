  {
    "row": 76,
    "rowsha": "ZeRfAmmuX7uhKDTqYN5BzpABDZcXjz9eDei4efupeGk=",
    "originContent": "| **Full** | Everything, every time | No | No |",
    "translatedContent": "| **ミラー** | 新規/変更ファイルのみ | はい | はい（孤立ファイル） |"
  },
