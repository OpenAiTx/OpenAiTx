  {
    "row": 47,
    "rowsha": "6LcakduaczZQCq0w63Dfehg4vFteQ2lx4/G2hO8LvHQ=",
    "originContent": "Create a TOML configuration file describing your gadget, then use the CLI to manage it:",
    "translatedContent": "가젯을 설명하는 TOML 구성 파일을 만든 다음 CLI를 사용하여 관리합니다:"
  },
  {
    "row": 48,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": ""
  },
  {
    "row": 49,
    "rowsha": "uWqF5D2jGmDz+N/+iNKp4L35d0Vx3LuA5yb6/Dl+CIE=",
    "originContent": "    usb-gadget up gadget.toml       # register and bind a gadget",
    "translatedContent": "    usb-gadget up gadget.toml       # 가젯 등록 및 바인딩"
  },
  {
    "row": 50,
    "rowsha": "qaq5aGdjTR6sFuf4sTKzpnyr3Oo3TAHiASsMvuTERwM=",
    "originContent": "    usb-gadget list                 # list registered gadgets",
    "translatedContent": "    usb-gadget list                 # 등록된 가젯 목록 보기"
  },
  {
    "row": 51,
    "rowsha": "6YoppkqHFwsNsi47JY4+LFZR7mvyEcElLBKM6N/3cP8=",
    "originContent": "    usb-gadget down my-gadget       # remove a gadget by name",
    "translatedContent": "    usb-gadget down my-gadget       # 이름으로 가젯 제거"
  },
  {
    "row": 52,
    "rowsha": "iFkSkVruycfanN2OoRHtAdo50go+CZTPMysvJCAr414=",
    "originContent": "    usb-gadget down --all           # remove all gadgets",
    "translatedContent": "    usb-gadget down --all           # 모든 가젯 제거"
  },
  {
    "row": 53,
    "rowsha": "O0wJGslNDaYmb2z0T+jm50Ye8pM5kAkhgENqi0Jf7gc=",
    "originContent": "    usb-gadget check gadget.toml    # validate a config file",
    "translatedContent": "    usb-gadget check gadget.toml    # 구성 파일 검증"
  },
  {
    "row": 54,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": ""
  },
