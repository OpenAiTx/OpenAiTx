    "originContent": "### Installation",
    "translatedContent": "### 설치"
  },
  {
    "row": 42,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": ""
  },
  {
    "row": 43,
    "rowsha": "PRj0I6OSMdr74NcRozMr3sek14d8CbBRUWodgmpiuGM=",
    "originContent": "    cargo install usb-gadget --features cli",
    "translatedContent": "    cargo install usb-gadget --features cli"
