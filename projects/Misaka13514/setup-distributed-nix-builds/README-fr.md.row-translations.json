    "originContent": "### Full Distributed Build Example",
    "translatedContent": "### Exemple complet de build distribué"
  },
  {
    "row": 106,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
