    "rowsha": "CoyFpSIJN/6OEHxY6zd/jndlpsEXJ4jxMd4F9dH6a8Q=",
    "originContent": "*Scratchpad:* `[ ] Work through tonight's backlog starting at 11pm`",
    "translatedContent": "*Notizblock:* `[ ] Arbeite das heutige Backlog ab, Beginn um 23 Uhr`"
  },
  {
    "row": 123,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
