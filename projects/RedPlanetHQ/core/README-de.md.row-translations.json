    "originContent": "*WhatsApp from the airport:* \"Ship the auth refactor.\"",
    "translatedContent": "*WhatsApp vom Flughafen:* \"Shippe das Auth-Refactoring.\""
  },
  {
    "row": 129,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
