  },
  {
    "row": 115,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": "*Ctrl+Option চেপি, ক'ব:* \"Fix the race condition in the checkout flow from issue #312.\""
  },
