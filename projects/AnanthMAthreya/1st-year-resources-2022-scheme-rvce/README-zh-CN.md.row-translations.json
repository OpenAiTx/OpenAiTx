  {
    "row": 12,
    "rowsha": "HVRZdwZyA3t81B3be8SdyxfaFSzfVT+qbr3SKzkOpEQ=",
    "originContent": "- The file size should not exceed 100 MB. If you want to add any textbook, then add only those chapters relevant to the course units must be added.",
