  {
    "row": 13,
    "rowsha": "NQGZ9K7FudfyiOQPJtkuB6BCeor3KKZHIyYjBhbLUUg=",
    "originContent": "This is the first of the [BoostServerTech projects](https://docs.google.com/document/d/1ZQrod1crs8EaNLLqSYIRMacwR3Rv0hC5l-gfL-jOp2M),",
    "translatedContent": "这是 [BoostServerTech 项目](https://docs.google.com/document/d/1ZQrod1crs8EaNLLqSYIRMacwR3Rv0hC5l-gfL-jOp2M) 系列的第一个项目，"
  },
  {
    "row": 14,
    "rowsha": "gMAFpRaXmcZMIoi5DkRE/Jz/zaaRwhu0Ht1HYDKWE/s=",
    "originContent": "a collection of projects that showcase how C++ and Boost can be used for server-side code.",
    "translatedContent": "该系列项目展示了如何使用 C++ 和 Boost 来编写服务器端代码。"
  },
  {
    "row": 15,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": ""
  },
