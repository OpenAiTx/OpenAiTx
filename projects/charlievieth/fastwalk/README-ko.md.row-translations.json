  },
  {
    "row": 22,
    "rowsha": "AALWYN99O5IsOZ3gG+1GBEsOls6+m2uvyP/wPQLtO3A=",
    "originContent": "* Safe symbolic link traversal ([`Config.Follow`](https://pkg.go.dev/github.com/charlievieth/fastwalk#Config))",
