    "row": 27,
    "rowsha": "kVnAtBrUzcoqdLLPvN6Z60uja2qQf3HlzHJlCEy5tm0=",
    "originContent": "\t[`IgnoreDuplicateDirs()`](https://pkg.go.dev/github.com/charlievieth/fastwalk#IgnoreDuplicateDirs)",
