  {
    "row": 16,
    "rowsha": "8QYjpoIvLUP9U+g183KfxXf04iOsgaOBcpUeIQm9EJs=",
    "originContent": "## Built with",
    "translatedContent": "## 사용 기술"
  },
  {
    "row": 17,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": ""
