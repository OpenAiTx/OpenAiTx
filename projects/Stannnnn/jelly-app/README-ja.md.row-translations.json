  {
    "row": 161,
    "rowsha": "dWrOGvzPJUVbFZpxg9RTt8RSqcfyCVMuOoDkgSc7GEA=",
    "originContent": "#### Docker Compose",
    "translatedContent": "#### Docker Compose"
  },
  {
    "row": 162,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
