    "originContent": "    JELLYAPP_PORT=80",
    "translatedContent": "    JELLYAPP_PORT=80"
  },
  {
    "row": 175,
    "rowsha": "58EYSAnNDhJjp7jz0EtsPOaixZliAs0mJfvvpPI6rqY=",
    "originContent": "    JELLYAPP_DEFAULT_URL=https://demo.jellyfin.org/stable",
    "translatedContent": "    JELLYAPP_DEFAULT_URL=https://demo.jellyfin.org/stable"
  },
  {
    "row": 176,
    "rowsha": "zhGpRgIXuQQ+/H74gUZqpND7AiB3rjHJYTyMlwnevu4=",
    "originContent": "    JELLYAPP_LOCK_URL=true",
    "translatedContent": "    JELLYAPP_LOCK_URL=true"
