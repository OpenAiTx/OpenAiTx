    "translatedContent": ""
  },
  {
    "row": 68,
    "rowsha": "HplGZp7mXz6LjSkaP96PmRRaLe8ewHeuqfjaP6HPJqQ=",
    "originContent": "The performance is achieved by [\"jwalk\"](https://crates.io/crates/jwalk/versions) and [\"Tauri\"](https://tauri.app/).",
    "translatedContent": "このパフォーマンスは [\"jwalk\"](https://crates.io/crates/jwalk/versions) と [\"Tauri\"](https://tauri.app/) によって実現されています。"
  },
  {
    "row": 69,
    "rowsha": "OciKUyMuNcbJt4DhtEgxyHre2Vl0BRhFko1G22PAezw=",
    "originContent": "<br/><br/>",
    "translatedContent": "<br/><br/>"
  },
  {
    "row": 70,
