    "row": 35,
    "rowsha": "LzuLYAfDOBzScV0X2lLcaYMjfrND3JuXvEIMfObQ6qQ=",
    "originContent": "### Protocol Enhancements",
    "translatedContent": "### 프로토콜 개선 사항"
  },
  {
    "row": 36,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
