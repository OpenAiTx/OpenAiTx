  },
  {
    "row": 32,
    "rowsha": "voVOiNqRtrjmeTZHsaCocs37bZFWHhU9R3/kln//CsY=",
    "originContent": "It allows you to protect your resources from unauthorized access and reduce your app's AAB size.",
    "translatedContent": "リソースの不正アクセスを防ぎ、アプリのAABサイズを削減することができます。"
  },
