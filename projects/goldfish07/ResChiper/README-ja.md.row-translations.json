  },
  {
    "row": 167,
    "rowsha": "lSM2nLdue+gFFiD2svdwSya/HMEKZo5xHbakHmx4Piw=",
    "originContent": "- `obfuscatedBundleName`: Name of the obfuscated AAB file.<br>",
