    "originContent": "```cmd",
    "translatedContent": "```cmd"
  },
  {
    "row": 150,
    "rowsha": "/R5sbNTF1mdrZjRJ1cxf4H8NQjNAq2+8Z2RpKpN0ego=",
    "originContent": "./gradle clean :app:resChiperDebug --stacktrace",
    "translatedContent": "./gradle clean :app:resChiperDebug --stacktrace"
  },
  {
