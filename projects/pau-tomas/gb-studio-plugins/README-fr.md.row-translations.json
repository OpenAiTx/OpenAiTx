    "rowsha": "5wL471phEuUXmv+qBsCTw6W+UU7ZN7uPSDct0cOdmkM=",
    "originContent": "Draw a (life/power/mana)bar to a specified position on the overlay.",
    "translatedContent": "Dessine une barre (vie/puissance/mana) à une position spécifiée sur la superposition."
  },
  {
    "row": 13,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": ""
  },
  {
    "row": 14,
    "rowsha": "+euZIWd3kNviNVu4Czqfd5t50w/UaCzLC5brQNyZLZM=",
    "originContent": "- `X`, `Y`: Tile coordinates on the overlay.",
    "translatedContent": "- `X`, `Y` : Coordonnées en tuiles sur la superposition."
  },
  {
    "row": 15,
    "rowsha": "Ic9FMHcOt3ffyk65C6BDi0JFPt7IheSVOxqpmaE7blw=",
    "originContent": "- `Tileset`: A tileset that includes the tiles for the bar in consecutive order.",
    "translatedContent": "- `Tileset` : Un tileset qui inclut les tuiles pour la barre dans l'ordre consécutif."
  },
  {
    "row": 16,
    "rowsha": "KFOLvXRywk+PFtw2CJtV/EsgwToc80JN4ChuEyFZ/O0=",
    "originContent": "- `Tile`: The first tile of the bar in the tileset (usually the empty tile).",
    "translatedContent": "- `Tile` : La première tuile de la barre dans le tileset (généralement la tuile vide)."
  },
  {
    "row": 17,
    "rowsha": "EVqZ1sgpOsthD9rmtTv1lxbnv/hH3Zbgxf9rEDMF08o=",
    "originContent": "- `Value`: The current value to be represented by the bar.",
    "translatedContent": "- `Value` : La valeur actuelle à représenter par la barre."
  },
  {
    "row": 18,
    "rowsha": "EaWN/qik9Mmit4ZzLAB1H0DAFJIxgECuVtXYnaQMH3I=",
    "originContent": "- `Max Value`: The maximum value that can be represented by the bar.",
    "translatedContent": "- `Max Value` : La valeur maximale pouvant être représentée par la barre."
  },
  {
    "row": 19,
    "rowsha": "LjEXqjYHHPEy9/BwlezSCJ4swzK533xuy1RRLwHOE7s=",
    "originContent": "- `Steps`: The number of tiles needed to \"fill\" an item in the bar (not including the empty one).",
    "translatedContent": "- `Steps` : Le nombre de tuiles nécessaires pour \"remplir\" un élément dans la barre (sans compter la tuile vide)."
  },
