  {
    "row": 29,
    "rowsha": "MkosR4ljDP+QtDJiOZdSMnRj8FtdJ06pMVEO3Tkx6J4=",
    "originContent": "### Display Advanced Menu",
    "translatedContent": "### Afficher un menu avancé"
  },
  {
    "row": 30,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
