    "row": 62,
    "rowsha": "K5uxX7jwofykCsVo3foSt1Ui0dj06gNRncwohz0hMzc=",
    "originContent": "Open your Terminal and type this:",
    "translatedContent": "Terminalinizi açın ve şunu yazın:"
  },
  {
    "row": 63,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
