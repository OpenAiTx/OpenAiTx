    "rowsha": "sp+nxwb3nrbqpFQPMQ34ovd0GZzjbbJ9CwDaYjP3wkk=",
    "originContent": "### Install WineZGUI",
    "translatedContent": "### WineZGUI'nin Kurulumu"
  },
