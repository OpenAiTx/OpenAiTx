    "rowsha": "qlAQxMPIoBvrFipf5Da4Es0AueKEvMNzZCZSo+3dT0g=",
    "originContent": "`flatpak override --user --filesystem=/path/to/your/drive io.github.fastrizwaan.WineZGUI`",
