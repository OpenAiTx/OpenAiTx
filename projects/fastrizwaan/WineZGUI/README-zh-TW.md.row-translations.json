    "originContent": "<a href=\"https://flathub.org/apps/details/io.github.fastrizwaan.WineZGUI\"><img width='240' alt='Download on Flathub' src='https://dl.flathub.org/assets/badges/flathub-badge-en.png'/></a>",
    "translatedContent": "<a href=\"https://flathub.org/apps/details/io.github.fastrizwaan.WineZGUI\"><img width='240' alt='Download on Flathub' src='https://dl.flathub.org/assets/badges/flathub-badge-en.png'/></a>"
