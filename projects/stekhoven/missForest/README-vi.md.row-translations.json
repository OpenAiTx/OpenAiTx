  {
    "row": 129,
    "rowsha": "g/co8j6XUTSclwVVZns62PpdBRMuVyRFZJRSzXDuZE8=",
    "originContent": "Key arguments:",
    "translatedContent": ""
  },
  {
    "row": 130,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "originContent": "",
    "translatedContent": "* `xmis` — data frame/matrix chứa giá trị thiếu (các cột phải là `numeric` hoặc `factor`)."
  },
  {
    "row": 131,
    "rowsha": "jL/x6Fz0dbzsmypaoAY1cMKOclQnTXk5mz00iRLTBR0=",
    "originContent": "* `xmis` — data frame/matrix with missing values (columns must be `numeric` or `factor`).",
    "translatedContent": "* `maxiter` — số vòng lặp tối đa (mặc định `10`)."
  },
  {
    "row": 132,
    "rowsha": "If4SF8hDkP/w8jJC/20wT6h5YhHEMHUn5OTlRa1kI8g=",
    "originContent": "* `maxiter` — maximum iterations (default `10`).",
    "translatedContent": "* `ntree` — số cây mỗi rừng (mặc định `100`)."
  },
  {
    "row": 133,
    "rowsha": "/PnoHYZsZdrBcpGmg5XS0n+D+WA87UUoUBDu4YCYoI4=",
    "originContent": "* `ntree` — trees per forest (default `100`).",
    "translatedContent": "* `mtry` — số biến thử nghiệm tại mỗi lần chia (mặc định `sqrt(p)`)."
  },
  {
    "row": 134,
    "rowsha": "vIEc4oU9x0t4NR/fYW7LFrY5ur85wqpOnsPjnY1Eop0=",
    "originContent": "* `mtry` — variables tried at each split (default `sqrt(p)`).",
    "translatedContent": "* `nodesize` — **mảng số độ dài-2**: kích thước nút tối thiểu cho **c(numeric, factor)**. Mặc định `c(5, 1)`."
  },
  {
    "row": 135,
    "rowsha": "ZgNqEzPG2zcB6BOVeG0cTISZDO0KEfML542ouXdJfOs=",
    "originContent": "* `nodesize` — **length-2 numeric**: minimum node size for **c(numeric, factor)**. Default `c(5, 1)`.",
    "translatedContent": "* `variablewise` — trả về lỗi OOB theo biến nếu `TRUE`."
  },
  {
    "row": 136,
    "rowsha": "1k0wbRQbQDO8PFknfqJT0L9Hs+Ri1juVktiwwnp+C+8=",
    "originContent": "* `variablewise` — return per-variable OOB error if `TRUE`.",
    "translatedContent": "* `parallelize` — `\"no\"`, `\"variables\"`, hoặc `\"forests\"`."
  },
  {
    "row": 137,
    "rowsha": "x/C/C2MD6K7W7Cp5s5DIiQBsRT83DANaxEANKoCNkaQ=",
    "originContent": "* `parallelize` — `\"no\"`, `\"variables\"`, or `\"forests\"`.",
    "translatedContent": "* `num.threads` — số luồng cho `ranger` (bỏ qua với `randomForest`)."
  },
  {
    "row": 138,
    "rowsha": "NYCEfXqJJXx1d/2vgUP2s1LiI+qpuXGGLnmHc6RSKMs=",
    "originContent": "* `num.threads` — threads for `ranger` (ignored by `randomForest`).",
    "translatedContent": "* `backend` — `\"ranger\"` (mặc định) hoặc `\"randomForest\"`."
  },
  {
    "row": 139,
    "rowsha": "3n5wgY/huM3VqhDC8qPgOm1xOWv7+6ssDPFs3nMEAYQ=",
    "originContent": "* `backend` — `\"ranger\"` (default) or `\"randomForest\"`.",
    "translatedContent": "* `xtrue` — dữ liệu đầy đủ tùy chọn để **benchmark** (thêm `$error`)."
  },
  {
    "row": 140,
    "rowsha": "15kjxz+KCZvxXQqu1nDj9D/P+oeYF4KiXSAxw2ib+X0=",
    "originContent": "* `xtrue` — optional complete data for **benchmarking** (adds `$error`).",
    "translatedContent": ""
  },
  {
    "row": 141,
    "rowsha": "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
