    "rowsha": "rTMjNc+qNIxb1xXDR5hEYiJw1fc4muBwuBsTXVIaIho=",
    "originContent": "```bash",
    "translatedContent": "```bash"
  },
  {
    "row": 23,
    "rowsha": "anmzsio0oSbgxu59cJx93Fjpl2E9ShpGtuzLkdikK40=",
    "originContent": "composer create-project freddie/mercure-x freddie && cd freddie",
    "translatedContent": "composer create-project freddie/mercure-x freddie && cd freddie"
  },
  {
    "row": 24,
    "rowsha": "aXGr4uJ7Ob4uiK4Wd47DcV7pnuija9IGyIOih6o1rqU=",
    "originContent": "bin/freddie",
    "translatedContent": "bin/freddie"
  },
  {
    "row": 25,
    "rowsha": "8bkBhHOQsO1+N058HkZOwXtGpCfEh6WtbL0pBkBQg9U=",
    "originContent": "```",
