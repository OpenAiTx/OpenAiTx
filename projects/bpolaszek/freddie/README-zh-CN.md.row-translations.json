  {
    "row": 6,
    "rowsha": "srDG4Cwue1yY3+zW90Wb9D3VFKnfpj+GEzkJJV34Tic=",
    "originContent": "Freddie is a PHP implementation of the [Mercure Hub Specification](https://mercure.rocks/spec).",
    "translatedContent": "Freddie 是 [Mercure Hub 规范](https://mercure.rocks/spec) 的 PHP 实现。"
  },
