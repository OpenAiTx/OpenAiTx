  },
  {
    "row": 74,
    "rowsha": "ne/kp1qkGOd84mIEuFO8qR8EObRlvXd42yfoP0fbC7k=",
    "originContent": "| **Ctrl + s**          | Download the database       |",
    "translatedContent": "| **Ctrl + ArrowRight** | 다음 페이지로 이동           |"
